{
    "version": 2,
    "builds": [
        {
            "src": "api/index.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "src/**",
                    "dist/**"
                ]
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "api/index.ts"
        },
        {
            "source": "/graphql",
            "destination": "api/index.ts"
        },
        {
            "source": "/health",
            "destination": "api/index.ts"
        }
    ]
}